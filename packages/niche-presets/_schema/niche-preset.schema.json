{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/niche-presets/_schema/niche-preset.schema.json",
  "title": "NichePreset",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "score1to10": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "presetStatus": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "editableBlock": {
      "type": "string",
      "enum": [
        "hero",
        "services",
        "prices",
        "team",
        "reviews",
        "contacts",
        "faq",
        "gallery",
        "cta"
      ]
    },
    "editableContentDefault": {
      "type": "string",
      "enum": [
        "discourage",
        "allow-if-qualified",
        "prefer-when-qualified"
      ]
    },
    "externalFlowPolicy": {
      "type": "string",
      "enum": [
        "preserve-front-layer",
        "preserve-and-require-approval",
        "preserve-and-bias-front-only"
      ]
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/definitions/presetStatus"
    },
    "applicability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "positive_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "negative_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "typical_offers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "site_clues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "positive_signals",
        "negative_signals",
        "typical_offers",
        "site_clues"
      ]
    },
    "taste": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "design_variance": {
          "$ref": "#/definitions/score1to10"
        },
        "motion_intensity": {
          "$ref": "#/definitions/score1to10"
        },
        "visual_density": {
          "$ref": "#/definitions/score1to10"
        }
      },
      "required": [
        "design_variance",
        "motion_intensity",
        "visual_density"
      ]
    },
    "copy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tone": {
          "type": "string"
        },
        "cta_bias": {
          "type": "string"
        },
        "trust_emphasis": {
          "type": "string"
        },
        "headline_style": {
          "type": "string"
        }
      },
      "required": [
        "tone",
        "cta_bias",
        "trust_emphasis",
        "headline_style"
      ]
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ordering_bias": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "required_sections",
        "optional_sections",
        "ordering_bias"
      ]
    },
    "qualification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "complexity_bias": {
          "type": "string"
        },
        "editable_content_default": {
          "$ref": "#/definitions/editableContentDefault"
        },
        "external_flow_policy": {
          "$ref": "#/definitions/externalFlowPolicy"
        }
      },
      "required": [
        "complexity_bias",
        "editable_content_default",
        "external_flow_policy"
      ]
    },
    "editingScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_editable_blocks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/editableBlock"
          },
          "uniqueItems": true
        }
      },
      "required": [
        "allowed_editable_blocks"
      ]
    },
    "designSeed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visual_direction": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "palette_direction": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "typography_direction": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "imagery_direction": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "visual_direction",
        "palette_direction",
        "typography_direction",
        "imagery_direction"
      ]
    },
    "approvalHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manual_review_required_when": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "do_not_auto_apply_when": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "manual_review_required_when",
        "do_not_auto_apply_when"
      ]
    }
  },
  "required": [
    "id",
    "label",
    "version",
    "status",
    "applicability",
    "taste",
    "copy",
    "layout",
    "qualification",
    "editingScope",
    "designSeed",
    "approvalHints"
  ]
}
