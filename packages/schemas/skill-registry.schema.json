{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/skill-registry.schema.json",
  "title": "SkillRegistry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "registryVersion": {
      "type": "string",
      "minLength": 1
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "skillId": {
            "type": "string",
            "minLength": 1
          },
          "sourcePath": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "draft",
              "deprecated"
            ]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "triggers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "upstreamArtifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "downstreamArtifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "boundaries": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "skillId",
          "sourcePath",
          "status",
          "purpose",
          "triggers",
          "upstreamArtifacts",
          "downstreamArtifacts",
          "boundaries",
          "notes"
        ]
      }
    }
  },
  "required": [
    "registryVersion",
    "skills"
  ]
}
