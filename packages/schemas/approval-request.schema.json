{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/approval-request.schema.json",
  "title": "ApprovalRequest",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "workMode": {
      "type": "string",
      "enum": [
        "autopilot",
        "checkpointed",
        "audit-only"
      ]
    },
    "pipelineDecision": {
      "type": "string",
      "enum": [
        "SKIP",
        "AUDIT_ONLY",
        "DEMO_FRONT_ONLY",
        "DEMO_EDITABLE_CONTENT"
      ]
    },
    "gateType": {
      "type": "string",
      "enum": [
        "decision-gate",
        "checkpoint-batch",
        "preview-gate"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "responded",
        "cancelled",
        "superseded"
      ]
    },
    "approvalReason": {
      "type": "string",
      "enum": [
        "EXTERNAL_FLOW_CASE",
        "CONFLICTING_SCORES",
        "LOW_CONFIDENCE_BORDERLINE",
        "CHECKPOINT_BATCH",
        "PREVIEW_GATE"
      ]
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactKind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "artifactKind",
        "ref"
      ]
    }
  },
  "properties": {
    "approvalRequestId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "batchId": {
      "type": "string",
      "minLength": 1
    },
    "gateType": {
      "$ref": "#/definitions/gateType"
    },
    "workMode": {
      "$ref": "#/definitions/workMode"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "leadKey": {
            "type": "string",
            "minLength": 1
          },
          "currentDecision": {
            "$ref": "#/definitions/pipelineDecision"
          },
          "approvalReasons": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/definitions/approvalReason"
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "leadKey",
          "currentDecision",
          "approvalReasons",
          "summary"
        ]
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/artifactRef"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "$ref": "#/definitions/status"
    }
  },
  "required": [
    "approvalRequestId",
    "runId",
    "batchId",
    "gateType",
    "workMode",
    "items",
    "summary",
    "createdAt",
    "status"
  ]
}