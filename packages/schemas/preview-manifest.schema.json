{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/preview-manifest.schema.json",
  "title": "PreviewManifest",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "previewDecision": {
      "type": "string",
      "enum": [
        "DEMO_FRONT_ONLY",
        "DEMO_EDITABLE_CONTENT"
      ]
    },
    "previewStatus": {
      "type": "string",
      "enum": [
        "requested",
        "building",
        "ready",
        "failed",
        "blocked"
      ]
    },
    "deploymentKind": {
      "type": "string",
      "enum": [
        "external-preview-deployment",
        "external-artifact"
      ]
    },
    "externalFlowMode": {
      "type": "string",
      "enum": [
        "not-applicable",
        "preserved-integration-point",
        "preserved-booking-surface",
        "preserved-cta-path"
      ]
    },
    "blocker": {
      "type": "string",
      "enum": [
        "APPROVAL_PENDING",
        "MISSING_REDESIGN_BRIEF",
        "MISSING_DEMO_BUILD_PLAN",
        "GENERATION_BOUNDARY_VIOLATION",
        "PREVIEW_BUILD_FAILED"
      ]
    }
  },
  "properties": {
    "previewId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "leadKey": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "$ref": "#/definitions/previewDecision"
    },
    "decisionRef": {
      "type": "string",
      "minLength": 1
    },
    "designSeedRef": {
      "type": "string",
      "minLength": 1
    },
    "redesignBriefRef": {
      "type": "string",
      "minLength": 1
    },
    "demoBuildPlanRef": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/definitions/previewStatus"
    },
    "deploymentKind": {
      "$ref": "#/definitions/deploymentKind"
    },
    "previewUrl": {
      "type": "string",
      "format": "uri"
    },
    "artifactUri": {
      "type": "string",
      "format": "uri"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "buildStoredInRepo": {
      "const": false
    },
    "externalFlowHandling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/definitions/externalFlowMode"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "mode",
        "notes"
      ]
    },
    "blockers": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/blocker"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "previewId",
    "runId",
    "leadKey",
    "decision",
    "decisionRef",
    "designSeedRef",
    "redesignBriefRef",
    "demoBuildPlanRef",
    "provider",
    "status",
    "deploymentKind",
    "generatedAt",
    "buildStoredInRepo",
    "externalFlowHandling"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ready"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "previewUrl"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "blocked",
              "failed"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "blockers"
        ],
        "properties": {
          "blockers": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "deploymentKind": {
            "const": "external-artifact"
          }
        },
        "required": [
          "deploymentKind"
        ]
      },
      "then": {
        "required": [
          "artifactUri"
        ]
      }
    }
  ]
}
