{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/skill-install-plan.schema.json",
  "title": "SkillInstallPlan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "registryRef": {
      "type": "string",
      "minLength": 1
    },
    "targetAgent": {
      "type": "string",
      "minLength": 1
    },
    "installEntries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "skillId": {
            "type": "string",
            "minLength": 1
          },
          "sourcePath": {
            "type": "string",
            "minLength": 1
          },
          "installScope": {
            "type": "string",
            "enum": [
              "project-local",
              "user-local"
            ]
          },
          "preferredInstallMode": {
            "type": "string",
            "enum": [
              "copy",
              "symlink"
            ]
          },
          "verificationNotes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "skillId",
          "sourcePath",
          "installScope",
          "preferredInstallMode",
          "verificationNotes"
        ]
      }
    },
    "syncPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceOfTruth": {
          "type": "string",
          "enum": [
            "repo-authored-source"
          ]
        },
        "installedCopyStatus": {
          "type": "string",
          "enum": [
            "disposable-operational-copy"
          ]
        },
        "driftResolution": {
          "type": "string",
          "enum": [
            "reinstall-from-source"
          ]
        },
        "editSurface": {
          "type": "string",
          "enum": [
            "repo-only"
          ]
        }
      },
      "required": [
        "sourceOfTruth",
        "installedCopyStatus",
        "driftResolution",
        "editSurface"
      ]
    },
    "verificationChecks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "planId",
    "registryRef",
    "targetAgent",
    "installEntries",
    "syncPolicy",
    "verificationChecks",
    "notes"
  ]
}
