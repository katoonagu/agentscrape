{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/redesign-brief.schema.json",
  "title": "RedesignBrief",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "decisionType": {
      "type": "string",
      "enum": ["DEMO_FRONT_ONLY", "DEMO_EDITABLE_CONTENT"]
    },
    "editableBlock": {
      "type": "string",
      "enum": [
        "hero",
        "services",
        "prices",
        "team",
        "reviews",
        "contacts",
        "faq",
        "gallery",
        "cta"
      ]
    },
    "externalFlowMode": {
      "type": "string",
      "enum": [
        "not-applicable",
        "preserved-integration-point",
        "preserved-booking-surface",
        "preserved-cta-path"
      ]
    },
    "pagePlanType": {
      "type": "string",
      "enum": ["multi-page-limited", "single-page-sections"]
    },
    "pageType": {
      "type": "string",
      "enum": ["home", "key-service", "contact-booking", "single-page"]
    }
  },
  "properties": {
    "briefId": {
      "type": "string",
      "minLength": 1
    },
    "leadKey": {
      "type": "string",
      "minLength": 1
    },
    "decisionType": {
      "$ref": "#/definitions/decisionType"
    },
    "designSeedRef": {
      "type": "string",
      "minLength": 1
    },
    "problemSummary": {
      "type": "string",
      "minLength": 1
    },
    "redesignGoals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "preservedConstraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "externalFlowHandling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/definitions/externalFlowMode"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["mode", "notes"]
    },
    "editableScope": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/editableBlock"
      }
    },
    "pagePlanSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "planType": {
          "$ref": "#/definitions/pagePlanType"
        },
        "plannedPages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "pageKey": {
                "type": "string",
                "minLength": 1
              },
              "pageType": {
                "$ref": "#/definitions/pageType"
              },
              "required": {
                "type": "boolean"
              }
            },
            "required": ["pageKey", "pageType", "required"]
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["planType", "plannedPages", "rationale"]
    },
    "sectionPlan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "scopeRef": {
            "type": "string",
            "minLength": 1
          },
          "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "required": ["scopeRef", "sections"]
      }
    },
    "copyDirection": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "visualDirection": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "nonGoals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvalRequired": {
      "type": "boolean"
    }
  },
  "required": [
    "briefId",
    "leadKey",
    "decisionType",
    "designSeedRef",
    "problemSummary",
    "redesignGoals",
    "preservedConstraints",
    "externalFlowHandling",
    "editableScope",
    "pagePlanSummary",
    "sectionPlan",
    "copyDirection",
    "visualDirection",
    "nonGoals",
    "approvalRequired"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "decisionType": {
            "const": "DEMO_FRONT_ONLY"
          }
        },
        "required": ["decisionType"]
      },
      "then": {
        "properties": {
          "editableScope": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decisionType": {
            "const": "DEMO_EDITABLE_CONTENT"
          }
        },
        "required": ["decisionType"]
      },
      "then": {
        "properties": {
          "editableScope": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
