{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/approval-response.schema.json",
  "title": "ApprovalResponse",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "pipelineDecision": {
      "type": "string",
      "enum": [
        "SKIP",
        "AUDIT_ONLY",
        "DEMO_FRONT_ONLY",
        "DEMO_EDITABLE_CONTENT"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approve-current",
        "downgrade-to-audit-only",
        "return-for-reevaluation"
      ]
    }
  },
  "properties": {
    "approvalResponseId": {
      "type": "string",
      "minLength": 1
    },
    "approvalRequestRef": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "batchId": {
      "type": "string",
      "minLength": 1
    },
    "operatorId": {
      "type": "string",
      "minLength": 1
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "leadKey": {
            "type": "string",
            "minLength": 1
          },
          "verdict": {
            "$ref": "#/definitions/verdict"
          },
          "resultingDecision": {
            "$ref": "#/definitions/pipelineDecision"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "leadKey",
          "verdict"
        ],
        "allOf": [
          {
            "if": {
              "properties": {
                "verdict": {
                  "const": "approve-current"
                }
              },
              "required": [
                "verdict"
              ]
            },
            "then": {
              "required": [
                "resultingDecision"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "verdict": {
                  "const": "downgrade-to-audit-only"
                }
              },
              "required": [
                "verdict"
              ]
            },
            "then": {
              "required": [
                "resultingDecision"
              ],
              "properties": {
                "resultingDecision": {
                  "const": "AUDIT_ONLY"
                }
              }
            }
          }
        ]
      }
    },
    "notes": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "approvalResponseId",
    "approvalRequestRef",
    "runId",
    "batchId",
    "operatorId",
    "decisions",
    "createdAt"
  ]
}