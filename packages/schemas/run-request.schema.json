{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/run-request.schema.json",
  "title": "RunRequest",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "workMode": {
      "type": "string",
      "enum": [
        "autopilot",
        "checkpointed",
        "audit-only"
      ]
    },
    "inputMode": {
      "type": "string",
      "enum": [
        "scrape",
        "manual-list"
      ]
    },
    "executionBoundary": {
      "type": "string",
      "enum": [
        "decision",
        "generation",
        "preview",
        "review"
      ]
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref"
      ]
    }
  },
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "operatorId": {
      "type": "string",
      "minLength": 1
    },
    "workMode": {
      "$ref": "#/definitions/workMode"
    },
    "inputMode": {
      "$ref": "#/definitions/inputMode"
    },
    "inputRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/reference"
      }
    },
    "executionBoundary": {
      "$ref": "#/definitions/executionBoundary"
    },
    "safeLimits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxLeads": {
          "type": "integer",
          "minimum": 1
        },
        "maxBuildableLeads": {
          "type": "integer",
          "minimum": 1
        },
        "maxPreviewLeads": {
          "type": "integer",
          "minimum": 1
        },
        "maxPagesPerLead": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "operatorNotes": {
      "type": "string"
    },
    "operatorReferences": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/reference"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "requestId",
    "operatorId",
    "workMode",
    "inputMode",
    "inputRefs",
    "executionBoundary",
    "createdAt"
  ]
}