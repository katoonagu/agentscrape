{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/run-manifest.schema.json",
  "title": "RunManifest",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "workMode": {
      "type": "string",
      "enum": [
        "autopilot",
        "checkpointed",
        "audit-only"
      ]
    },
    "runState": {
      "type": "string",
      "enum": [
        "RUN_CREATED",
        "INPUT_SELECTED",
        "INGESTING",
        "NORMALIZED",
        "DEDUPED_BY_DOMAIN",
        "QUALIFYING",
        "DECISION_MADE",
        "GENERATING_DEMO",
        "INTERNAL_QA",
        "AWAITING_APPROVAL",
        "DEPLOYING_PREVIEW",
        "PREVIEW_READY",
        "GENERATING_REVIEW",
        "RUN_DONE",
        "FAILED_RETRYABLE",
        "FAILED_FINAL",
        "CANCELLED",
        "PARTIAL_DONE"
      ]
    },
    "pipelineDecision": {
      "type": "string",
      "enum": [
        "SKIP",
        "AUDIT_ONLY",
        "DEMO_FRONT_ONLY",
        "DEMO_EDITABLE_CONTENT"
      ]
    }
  },
  "properties": {
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "workMode": {
      "$ref": "#/definitions/workMode"
    },
    "runState": {
      "$ref": "#/definitions/runState"
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "scrape",
            "manual-list"
          ]
        },
        "sourceRef": {
          "type": "string"
        },
        "requestedLeadCount": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "kind",
        "requestedLeadCount"
      ]
    },
    "leads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "leadKey": {
            "type": "string",
            "minLength": 1
          },
          "leadRef": {
            "type": "string"
          },
          "currentState": {
            "$ref": "#/definitions/runState"
          },
          "decision": {
            "$ref": "#/definitions/pipelineDecision"
          },
          "qualificationRef": {
            "type": "string"
          },
          "decisionRef": {
            "type": "string"
          },
          "designSeedRef": {
            "type": "string"
          },
          "redesignBriefRef": {
            "type": "string"
          },
          "demoBuildPlanRef": {
            "type": "string"
          },
          "previewManifestRef": {
            "type": "string"
          },
          "reviewDossierRef": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "leadKey",
          "currentState"
        ]
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalLeads": {
          "type": "integer",
          "minimum": 0
        },
        "withSite": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "auditOnly": {
          "type": "integer",
          "minimum": 0
        },
        "demoFrontOnly": {
          "type": "integer",
          "minimum": 0
        },
        "demoEditableContent": {
          "type": "integer",
          "minimum": 0
        },
        "previewReady": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "totalLeads",
        "withSite",
        "skipped",
        "auditOnly",
        "demoFrontOnly",
        "demoEditableContent",
        "previewReady"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "qualification-bundle",
              "decision-bundle",
              "preview-bundle",
              "review-dossier"
            ]
          },
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "locationKind": {
            "type": "string",
            "enum": [
              "external-artifact",
              "external-preview",
              "local-doc"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "kind",
          "uri",
          "locationKind"
        ]
      }
    }
  },
  "required": [
    "runId",
    "createdAt",
    "workMode",
    "runState",
    "input",
    "leads",
    "counts"
  ]
}
