{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentscrape.local/schemas/operator-audit-log.schema.json",
  "title": "OperatorAuditLog",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "eventType": {
      "type": "string",
      "enum": [
        "RUN_REQUESTED",
        "RUN_STARTED",
        "APPROVAL_REQUESTED",
        "APPROVAL_RESPONDED",
        "OVERRIDE_APPLIED",
        "LEAD_RETRIED",
        "RUN_RESUMED",
        "RUN_CANCELLED",
        "NOTE_ADDED"
      ]
    },
    "actorType": {
      "type": "string",
      "enum": [
        "operator",
        "system"
      ]
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "kind",
        "ref"
      ]
    }
  },
  "properties": {
    "auditLogId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "eventId": {
            "type": "string",
            "minLength": 1
          },
          "eventType": {
            "$ref": "#/definitions/eventType"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "actorType": {
            "$ref": "#/definitions/actorType"
          },
          "operatorId": {
            "type": "string"
          },
          "leadKey": {
            "type": "string"
          },
          "batchId": {
            "type": "string"
          },
          "artifactRefs": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/artifactRef"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "eventId",
          "eventType",
          "timestamp",
          "actorType"
        ],
        "allOf": [
          {
            "if": {
              "properties": {
                "actorType": {
                  "const": "operator"
                }
              },
              "required": [
                "actorType"
              ]
            },
            "then": {
              "required": [
                "operatorId"
              ]
            }
          }
        ]
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "auditLogId",
    "runId",
    "events",
    "createdAt",
    "updatedAt"
  ]
}